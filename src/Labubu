    function _hour4Start(uint256 ts) internal pure returns (uint256) {
        return (ts / WINDOW_TIME) * WINDOW_TIME;
    }

    function getTokenPriceUsdt() public view returns (uint256) {
        uint256 bnbPrice = getCurrentPrice(bnbTokenAddress, baseTokenAddress);
        uint256 thisPrice = getCurrentPrice(address(this), bnbTokenAddress);
        return (bnbPrice   * thisPrice) / 1e18;
    }
    function getCurrentPrice(
        address tokenA,
        address tokenB
    ) public view returns (uint256) {
        address pair = IUniswapV2Factory(uniswapV2Router.factory()).getPair(
            tokenA,
            tokenB
        );
        (uint112 r0, uint112 r1, ) = IUniswapV2Pair(pair).getReserves();
        if (r0 == 0 || r1 == 0) {
            return 0;
        }

        address t0 = IUniswapV2Pair(pair).token0();
        if (tokenA == t0) {
            return (uint256(r1) * 1e18) / uint256(r0);
        } else {
            return (uint256(r0) * 1e18) / uint256(r1);
        }
    }
