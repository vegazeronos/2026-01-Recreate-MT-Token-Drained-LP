    function swapSellAward(address from, uint256 amount) internal returns (uint256){
        uint256 sellFeeAmount = amount.mul(sellRate).div(BASE_PERCENT);
        //super._update(from, address(this), sellFeeAmount);
        //tokenToEthSwap(sellFeeAmount, sellFeeBNBAddress);
        uint256 _amount = amount.sub(sellFeeAmount);

        uint256 taxAmount = sellFeeAmount;
        uint256 taxAmount2 = 0;
        if (isUpdateHourlyLow) {
            (
                uint256 percent,
                uint8 position
            ) = percentChangeFrom24hLowest();
            if (position > 0) {
                 taxAmount2 = (amount * percent * 2) / BASE_PERCENT;
                if (taxAmount2 + taxAmount > amount) {
                    taxAmount2 = amount - taxAmount;
                }
                //super._update(from, BURN_ADDRESS, taxAmount2);
                //super._update(from, address(this), taxAmount2);
                //tokenToEthSwap(taxAmount2, sellFeeBNBAddress);
                _amount -= taxAmount2;
            }
        }  
        super._update(from, address(this), sellFeeAmount+taxAmount2);
        tokenToEthSwap(sellFeeAmount+taxAmount2, sellFeeBNBAddress);
        return _amount;
    }

    function isLpValueAboveThreshold(address user) internal view returns (bool) {
        IUniswapV2Pair pair = IUniswapV2Pair(uniswapPair);

        (uint112 reserve0, uint112 reserve1, ) = pair.getReserves();
        uint256 totalSupply = pair.totalSupply();

        if (totalSupply == 0) return false; // 

        address token0 = pair.token0();

        // left or right BNB
        (uint256 reserveBNB, ) = token0 == bnbTokenAddress
            ? (reserve0, reserve1)
            : (reserve1, reserve0);

        uint256 userLP = pair.balanceOf(user);
        uint256 userShare = userLP.mul(1e18).div(totalSupply);

        uint256 bnbAmount = reserveBNB.mul(userShare).div(1e18);

        uint256 lpValueInBNB = bnbAmount.mul(2);
        
        return lpValueInBNB >= minAmount.div(4);//minAmount.div(2)
    }


    function isChildListLpValueAboveThreshold(address account, uint256 num) internal view returns (bool) {
        uint256 validNum;
        for (uint8 i = 0; i < inviterChildList[account].length(); i++) {
            address c = inviterChildList[account].at(i);
            bool valid = isLpValueAboveThreshold(c);
            if (valid){
                validNum = validNum.add(1);
            }
            if (validNum >= num) {
                break ;
            }
        }

        return validNum >= num;
    }

    function isChildListDepositAboveThreshold(address account, uint256 num) internal view returns (bool) {
        uint256 validNum;
        for (uint8 i = 0; i < inviterChildList[account].length(); i++) {
            address c = inviterChildList[account].at(i);
            if (accountSales[c] >= minAmount) {
                validNum = validNum.add(1);
            }
            if (validNum >= num) {
                break;
            }
        }

        return validNum >= num;
    }


    event DistributeReferralReward(address indexed from, address indexed to, uint8 indexed level, uint256 amount);
    event NFTGranted(address indexed recipient, uint256 timestamp);
    function _distributeReferralReward(address user, uint256 _totalAmount, uint256 totalReward) internal {
        address current = user;
        uint256 distributedReward = 0;

        for (uint8 i = 0; i < 15; i++) {//10
            current = inviter[current];
            if (current == address(0)) {
                break;
            }

            uint256 rate = InvitationAwardRates[i]; 
            uint256 reward = _totalAmount.mul(rate).div(BASE_PERCENT);
            if (reward == 0) {
                continue;
            }

            bool eligible = false;
            
            if (!lpCheckEnabled) {
                eligible = true;
            } else {
                if (i == 0) {
                    eligible = isLpValueAboveThreshold(current);
                } else if (i == 1) {
                    eligible = isLpValueAboveThreshold(current) && isChildListLpValueAboveThreshold(current, 2);//3
                } else if (i == 2) {
                    eligible = isLpValueAboveThreshold(current) && isChildListLpValueAboveThreshold(current, 3);//5
                } else if (i == 3) {
                    eligible = isLpValueAboveThreshold(current) && isChildListLpValueAboveThreshold(current, 4);//7
                } else {
                    eligible = isLpValueAboveThreshold(current) && isChildListLpValueAboveThreshold(current, 4);//10
                }
            }

			if (i == 0 && !hasReceivedReferralNFT[current]) {
				if(isChildListDepositAboveThreshold(current, maxNftUser))
				{
					if(fbubu2NFT.getAvailableNFTCount()>0)
					{
						fbubu2NFT.giftNFT(current);
						hasReceivedReferralNFT[current] = true;
						emit NFTGranted(current, block.timestamp);
					}
					
				}
			}

            if (eligible) {
                payable(current).transfer(reward);
                emit DistributeReferralReward(user, current, i + 1, reward);
                distributedReward = distributedReward.add(reward);
            }
        }

        //NFT 5%
        uint256 nft = 0;
        if(mintNFTAddress != address(0)) {
            nft = _totalAmount.mul(500).div(BASE_PERCENT);//_totalAmountguo
             (bool sent, bytes memory data) = payable(mintNFTAddress).call{gas: 2300*100, value: nft}("");
             require(sent, "Failed to send NFT");
        }
		
		//AI 3% ai--》10%
		uint256 aiMoney = 0;
		if(aiAddress != address(0)) {
		    aiMoney = _totalAmount.mul(1000).div(BASE_PERCENT);//_totalAmountguo
		     (bool sent, bytes memory data) = payable(aiAddress).call{gas: 2300*100, value: aiMoney}("");
		     require(sent, "Failed to send aiMoney");
		}
        
        // all left ko
        uint256 remaining = totalReward.sub(distributedReward).sub(nft).sub(aiMoney);
        if (remaining > 0) {
            payable(inviteAddress).transfer(remaining);
        }
    }


    uint256 public lastTriggerTime = block.timestamp;
    uint256 public holdLPAward;
    uint256 public TRIGGER_INTERVAL = 6 hours;
    event TriggerDailyBurnAndMint(uint256 indexed liquidityPairBalance, uint256 indexed burnAmount, uint256 indexed holdLPAwardAmount, uint256 rounds);
    function _triggerDailyBurnAndMint() internal {
        uint256 nowTime = block.timestamp;
        if (nowTime <= lastTriggerTime + TRIGGER_INTERVAL) {
            return;
        }

        uint256 rounds = (nowTime - lastTriggerTime) / TRIGGER_INTERVAL;
        lastTriggerTime += rounds * TRIGGER_INTERVAL;

        uint256 liquidityPairBalance = this.balanceOf(uniswapPair);
        if (liquidityPairBalance == 0) return;
        //
        uint256 holdLPAwardRate = distributeRate;
        if (holdLPAwardRate > 9000) {
            holdLPAwardRate = 9000;
        } else {
            distributeRate = (distributeRate * 10060) / BASE_PERCENT;
        }
        uint256 blackAndLPAwardAmount = 
            liquidityPairBalance.mul(
                    BURN_BLACK_PERCENT.add(BURN_AWARD_PERCENT)
                ).mul(rounds).div(BASE_PERCENT);	// <-- this code is suspicious
        uint256 holdLPAwardAmount = blackAndLPAwardAmount.mul(holdLPAwardRate).div(BASE_PERCENT);
        if (holdLPAwardAmount > 0) {
            super._update(uniswapPair, address(lpAddress), holdLPAwardAmount);
            // holdLPAward = holdLPAward.add(holdLPAwardAmount);
            
        }
	
	uint256 blackAmount =blackAndLPAwardAmount.sub(holdLPAwardAmount);
	if (blackAmount > 0) {
            super._update(uniswapPair, BLACK_ADDRESS, blackAmount);
        }

        emit TriggerDailyBurnAndMint(liquidityPairBalance, blackAmount, holdLPAwardAmount, rounds);
        
        
        IUniswapV2Pair(uniswapPair).sync();
    }


