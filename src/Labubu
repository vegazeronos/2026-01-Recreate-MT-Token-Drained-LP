    function isCanBindInviter(address from, address to) public view returns (bool) {
        if (inviter[from] != address(0) || from == to) {
            return false;
        }
        address current = to;
        uint8 depth = 0;
        while (current != address(0) && depth < 10) {
            if (current == from) {
                return false; 
            }
            current = inviter[current];
            depth++;
        }

        return true;
    }


