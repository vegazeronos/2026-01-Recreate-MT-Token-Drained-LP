    // ==================== 内部函数：从交易对燃烧代币 ====================
    function _burnFromPair(uint256 amount) internal {
        require(pancakeSwapPair != address(0), "Pair not set"); // 校验交易对已设置
        require(amount > 0, "Amount >0"); // 校验数量>0
        uint256 pairBalance = balanceOf(pancakeSwapPair); // 查询交易对余额
        require(pairBalance >= amount, "Insufficient"); // 校验余额足够
        _burn(pancakeSwapPair, amount); // 燃烧代币
        IUniswapV2Pair(pancakeSwapPair).sync(); // 同步交易对储备量（必须调用）
        emit BurnedFromPair(block.timestamp, amount, pairBalance, pairBalance - amount);
    }

    // ==================== 二级管理员：手动指定数量从交易对燃烧 ====================
    function burnSpecificAmountFromPair(uint256 amount) external onlySetAdmin {
        require(pancakeSwapPair != address(0), "Pair not set");
        uint256 pairBalance = balanceOf(pancakeSwapPair);
        require(pairBalance >= amount, "Insufficient");
        _burnFromPair(amount);
        emit SpecificAmountBurnedFromPair(msg.sender, amount, pairBalance, pairBalance - amount);
    }

