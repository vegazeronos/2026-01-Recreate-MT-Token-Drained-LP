// PancakeSwap V2路由核心接口（仅保留用到的函数）
interface IUniswapV2Router02 {
    function factory() external pure returns (address); // 工厂合约地址
    function WETH() external pure returns (address); // WBNB地址
    // 支持手续费代币的：代币兑换ETH（BNB）
    function swapExactTokensForETHSupportingFeeOnTransferTokens(
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external;
}

// PancakeSwap LP池接口（仅保留用到的函数）
interface IUniswapV2Pair {
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast); // 获取储备量
    function token0() external view returns (address); // 代币0地址
    function token1() external view returns (address); // 代币1地址
    function balanceOf(address owner) external view returns (uint256); // 查询余额
    function sync() external; // 同步储备量（燃烧后必须调用）
}

