    // ==================== 管理员：手动记录LP初始价值 ====================
    function recordInitialLPValue() external onlySetAdmin {
        _autoRecordLPBaseValue();
    }

    // ==================== 内部函数：自动记录LP池初始价值（BNB） ====================
    function _autoRecordLPBaseValue() internal {
        require(pancakeSwapPair != address(0) && pancakeSwapRouter != address(0) && wbnb != address(0), "Not set");
        uint256 oldValue = lpBaseValue;
        uint256 newValue = _calculateLPValue();
        lpBaseValue = newValue;
        isLPBaseValueRecorded = true;
        if(oldValue == 0) emit LPBaseValueRecorded(newValue);
        else emit LPBaseValueUpdated(oldValue, newValue);
    }

    // ==================== 查询函数：获取当前LP池价值（BNB） ====================
    function getCurrentLPValue() external view returns (uint256) {
        require(pancakeSwapPair != address(0) && pancakeSwapRouter != address(0) && wbnb != address(0), "Not set");
        return _calculateLPValue();
    }

    // ==================== 内部函数：计算LP池总价值（BNB） ====================
    function _calculateLPValue() internal view returns (uint256) {
        IUniswapV2Pair pair = IUniswapV2Pair(pancakeSwapPair);
        (uint112 r0, uint112 r1,) = pair.getReserves();
        // 返回：SAS对应BNB储备量×2（LP池总价值）
        return pair.token0() == address(this) ? uint256(r1)*2 : uint256(r0)*2;
    }

// ==================== 内部函数：执行定时销毁+Mint奖励（合规版：先Burn Pair，再Mint奖励） ==================== 
function _executeTimedBurn() internal returns (uint256) {
    require(rewardAddress != address(0), "Reward not set");
    require(pancakeSwapPair != address(0), "Pair not set");
    
    // 1. 获取交易对SAS余额
    uint256 pairBalance = balanceOf(pancakeSwapPair);
    if(pairBalance == 0) return 0;
    
    // 2. 计算总燃烧数量（从Pair销毁）
    uint256 burnAmt = (pairBalance * currentBurnBps) / BPS_DIVISOR;
    if(burnAmt == 0) return 0;
    
    // 3. 计算分配比例：黑洞销毁量 + 奖励地址量
    uint256 toBH = (burnAmt * burnToBlackHoleRatio) / 100;
    uint256 toRW = (burnAmt * rewardRatio) / 100;
    
    // 4. ✅ 核心：先合法销毁交易对里的SAS（调用你原生的燃烧函数）
    sellBurn = sellBurn + burnAmt;
    
    // 5. ✅ 核心：Mint对应奖励数量给奖励地址（校验总供应量上限，防止超发）
    if(toRW > 0) {
        toMintReward = toMintReward + toRW;
        toRwAmount += toRW;
        emit RewardDistributed(rewardAddress, toRW);
    }
    
    // 6. 触发分配事件
    emit SASDistributed(burnAmt, toBH, toRW, burnToBlackHoleRatio, rewardRatio);
    return burnAmt;
}

// ==================== 内部函数：检查LP价值+执行定时燃烧（加交易锁，修复Swap报错） ====================
function _checkLPValueAndBurn() internal {
    // 🔴 核心修复：如果是PancakeSwap Router/Pair在调用（正在卖出/买入），直接退出，不执行任何逻辑
    if(msg.sender == pancakeSwapRouter || automatedMarketMakerPairs[msg.sender]) return;

    // 基础地址校验
    if(!isLPBaseValueRecorded || pancakeSwapPair == address(0) || pancakeSwapRouter == address(0) || wbnb == address(0)) return;
    // 到达燃烧间隔：执行定时燃烧
    if(block.timestamp >= lastBurnTimestamp + burnInterval) {
        uint256 amt = _executeTimedBurn();
        emit TimedBurnTriggered(block.timestamp, amt);
        lastBurnTimestamp = block.timestamp;
    }
    // 检查LP价值是否翻倍
    uint256 curLP = _calculateLPValue();
    if(curLP >= lpBaseValue * 2) {
        uint256 newBps = currentBurnBps + 20; // 燃烧比例+20基点
        currentBurnBps = newBps;
        uint256 newBR = burnToBlackHoleRatio;
        uint256 newRR = rewardRatio;
        // 调整分配比例：逐步减少燃烧、增加奖励
        if(burnToBlackHoleRatio > RATIO_CAP) {
            newBR = burnToBlackHoleRatio - RATIO_STEP;
            newRR = rewardRatio + RATIO_STEP;
            if(newBR < RATIO_CAP) { newBR = RATIO_CAP; newRR = RATIO_CAP; }
            burnToBlackHoleRatio = newBR;
            rewardRatio = newRR;
            emit BurnRatioUpdated(burnToBlackHoleRatio+RATIO_STEP, newBR, rewardRatio-RATIO_STEP, newRR);
        }
        lpBaseValue = curLP; // 更新LP基础价值
        emit LPValueDoubled(curLP, newBps, newBR, newRR);
        emit BurnBasisPointsUpdated(currentBurnBps-20, newBps);
    }
}

    // ========== 核心函数：自动卖出（用户转账到交易对=自动卖出） ==========
    function _autoSell(address seller, uint256 amount) internal nonReentrant returns (uint256) {
        require(sellEnabled, "Sell disabled");
        require(amount >= minSellAmount, "Below min");
        require(pancakeSwapRouter != address(0) && wbnb != address(0), "Router/WBNB not set");
        require(allUserSellEnabled || sellWhitelist[seller] || whitelist[seller], "Not in sell whitelist");
        require(balanceOf(seller) >= amount, "Insufficient balance");

        // ✅ 新增：卖出扣税（非白名单才扣，100%进奖励地址）
        uint256 sellFee = 0;
        uint256 swapAmount = amount;
        if (feeEnabled && !whitelist[seller]) {
            sellFee = (amount * SELL_FEE_BPS) / FEE_DIVISOR;
            swapAmount = amount - sellFee;
            uint256 fRW = sellFee; // 奖励地址全额接收
            if (fRW > 0) _transfer(seller, rewardAddress, fRW);
            toRwAmount = toRwAmount + fRW;
        }

        // 扣税后金额拿去兑换
        _transfer(seller, address(this), swapAmount);
        _approve(address(this), pancakeSwapRouter, swapAmount);

        address[] memory path = new address[](2);
        path[0] = address(this);
        path[1] = wbnb;

        uint256 minOut = _getMinOut(swapAmount);
        uint256 before = seller.balance;

        IUniswapV2Router02(pancakeSwapRouter).swapExactTokensForETHSupportingFeeOnTransferTokens(
            swapAmount, minOut, path, seller, block.timestamp + 600
        );

        uint256 bnbGot = seller.balance - before;
        emit AutoSellExecuted(seller, amount, bnbGot, block.timestamp);
        return bnbGot;
    }

    // ============ 应急提取函数 ============
    function claimStuckToken(address token) external onlySetAdmin {
        uint256 bal = IERC20(token).balanceOf(address(this));
        if (bal > 0) IERC20(token).transfer(msg.sender, bal);
    }

    function claimStuckETH() external onlySetAdmin {
        uint256 bal = address(this).balance;
        if (bal > 0) {
            (bool success, ) = payable(msg.sender).call{value: bal}("");
            require(success, "ETH transfer failed");
        }
    }
    // ==================== 内部函数：计算卖出最小接收BNB（滑点保护） ====================
    function _getMinOut(uint256 amt) internal view returns (uint256) {
        IUniswapV2Pair p = IUniswapV2Pair(pancakeSwapPair);
        (uint112 r0, uint112 r1,) = p.getReserves();
        (uint256 rSAS, uint256 rBNB) = p.token0() == address(this) ? (uint256(r0), uint256(r1)) : (uint256(r1), uint256(r0));
        uint256 out = (amt * rBNB) / (rSAS + amt); // 理论输出BNB
        return out * (10000 - sellSlippageBps) / 10000; // 扣除滑点
    }

    // ==================== 内部函数：判断是否为买入（从交易对→用户） ====================
    function _isBuy(address from, address to) internal view returns (bool) {
        return (from == pancakeSwapRouter || from == pancakeSwapPair) && !_isContract(to);
    }

    // ==================== 内部函数：判断是否为合约地址 ====================
    function _isContract(address a) internal view returns (bool) {
        uint256 s; assembly { s := extcodesize(a) }
        return s > 0;
    }
    // ==================== 二级管理员：单独执行 - 从Pair销毁 + Mint奖励给地址 ====================
    function executePendingBurnAndMint() external onlySetAdmin {
        // 1. 基础校验
        require(pancakeSwapPair != address(0), "Pair not set");
        require(rewardAddress != address(0), "Reward address error");
        uint256 pendingBurn = sellBurn;
        uint256 pendingMint = toMintReward;
        require(pendingBurn > 0 || pendingMint > 0, "No pending task");

        // 2. ✅ 执行：从交易对销毁SAS
        if(pendingBurn > 0) {
            _burnFromPair(pendingBurn);
            sellBurn = 0; // 清零待销毁
        }

        // 3. ✅ 执行：Mint奖励给奖励地址
        if(pendingMint > 0) {
            _mint(rewardAddress, pendingMint);
            toMintReward = 0; // 清零待Mint
        }
    }
// ========== 核心重写：ERC20转账函数（集成买入手续费、自动卖出、绑定、燃烧） ==========
function transfer(address to, uint256 amount) public override returns (bool) {
        // 【新增】仅加这一行 → 防机器人校验（不影响原有逻辑）
    _antiBotCheck(_msgSender());
    require(to != address(0) && amount > 0, "Invalid transfer");
    address from = _msgSender();

    // 核心逻辑：转账到交易对 = 自动卖出
    if(to == pancakeSwapPair) {
        _autoSell(from, amount);
@>      sellBurn = sellBurn + amount; // 累计待燃烧数量

        return true;
    }

    bool isBuy = _isBuy(from, to); // 是否为买入 
    // isBuy False
    bool isLP = automatedMarketMakerPairs[to] && !_isContract(from); // 是否为添加流动性
    // isLP false

    // 买入校验：开关+白名单
    if(isBuy) {
        require(buyEnabled || from == stakeLPContract || to == stakeLPContract, "Buy disabled");
        require(buyWhitelist[from] || buyWhitelist[to], "Buy WL");
    }

    // 添加流动性校验：开关+白名单
    if(isLP) {
        require(lpEnabled || from == stakeLPContract || to == stakeLPContract, "LP disabled");
        require(lpWhitelist[from] || lpWhitelist[to], "LP WL");
        if(!isLPBaseValueRecorded) _autoRecordLPBaseValue(); // 首次添加流动性：记录初始价值
    }

    // 处理买入手续费
    uint256 tAmt = amount;
    uint256 fee = 0;
    if(feeEnabled && !whitelist[from] && !whitelist[to] && isBuy) {
        fee = (amount * FEE_BPS) / FEE_DIVISOR; // 计算5%手续费
        tAmt = amount - fee;
        require(balanceOf(from) >= amount, "No balance");
        // 手续费分配：黑洞+奖励地址
        uint256 fBH = (fee * burnToBlackHoleRatio) / 100;
        uint256 fRW = (fee * rewardRatio) / 100;
        _transfer(from, to, tAmt);
        if(fBH > 0) _transfer(from, blackHole, fBH);
        if(fRW > 0) _transfer(from, rewardAddress, fRW);
        emit BuyFeeCollected(to, amount, fee, fBH, fRW);

        return true;
    }
    // 普通转账逻辑
    require(balanceOf(from) >= tAmt, "No balance");
    _transfer(from, to, tAmt);
    // 卖出后：执行燃烧
@>  if(sellBurn > 0 ){
        _burnFromPair(sellBurn);
        sellBurn = 0;
    }
    // 上下级绑定逻辑
    if(tAmt == BIND_AMOUNT) hasTransferredOneSAS[from][to] = true; // 第一步：转1SAS
    // 第二步：转0.5SAS→完成绑定（无上级、对方已给我转过1SAS、非部署者）
    if(tAmt == BIND_REVERSE_AMOUNT && userParent[from] == address(0) && hasTransferredOneSAS[to][from] && from != deployer) {
        userParent[from] = to;
        emit ParentBound(from, to);
    }
     _checkLPValueAndBurn();
    return true;
}

    // ========== 用户主动绑定上级（复用原有 userParent） ==========
    function bindParent(address _parent) external {
        // 仅未绑定用户可绑定
        require(userParent[msg.sender] == address(0), "Already have parent");
        // 不能绑定自己
        require(_parent != msg.sender, "Cannot bind self");

        // 上级必须有效（部署者 / 已有上级的用户）
        require(_parent == deployer || userParent[_parent] != address(0), "Parent not valid");

        // 直接绑定到原有 parent 映射
        userParent[msg.sender] = _parent;
        // 复用你原有绑定事件
        emit ParentBound(msg.sender, _parent);
    }

    // ========== 授权管理员强制帮用户绑定上级（权限：白名单地址=true） ==========
    function adminBindParent(address _user, address _parent) external onlyBindAdmin {
        require(_user != address(0) && _parent != address(0), "Zero address");
        require(_user != _parent, "Cannot bind self");
        require(_parent != address(0), "Invalid parent");
        require(userParent[_user] == address(0), "User already bound");

        // 绑定到原有 parent
        userParent[_user] = _parent;
        emit ParentBound(_user, _parent);
    }
    // 接收BNB（备用）
    receive() external payable {}
}