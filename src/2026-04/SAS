        antiBotEnabled = _enabled;
        forbidContractTrade = _forbidContract;
    }

    // 设置防bot白名单（放行必要合约：stakeLP/Router/Pair）
    function setBotWhitelist(address _contractAddr, bool _isWhitelisted) external onlySetAdmin {
        require(_contractAddr != address(0), "Zero address");
        botWhitelist[_contractAddr] = _isWhitelisted;
    }

    // 【内部】防bot校验核心（拦截恶意合约）
    function _antiBotCheck(address _sender) internal view {
        // 防bot关闭 → 跳过校验
        if(!antiBotEnabled) return;
        
        // 放行名单（绝对不拦截，保证业务正常）
        if(
            whitelist[_sender] ||        // 全局白名单用户
            _sender == stakeLPContract ||// LP质押合约（核心！必须放行）
            _sender == pancakeSwapRouter || // 交易路由
            _sender == pancakeSwapPair ||   // LP交易对
            botWhitelist[_sender] ||    // 防bot白名单合约
            _sender == owner() ||        // 主管理员
            _sender == setAdmin          // 二级管理员
        ) {
            return;
        }

        // 禁止合约交易 → 拦截所有非放行的合约地址（机器人/夹子全是合约）
        if(forbidContractTrade) {
            require(!_isContract(_sender), "AntiBot: Contract trade forbidden");
        }
    }
